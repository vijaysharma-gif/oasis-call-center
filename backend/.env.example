PORT=3001
NODE_ENV=production

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# BuzzDial / telephony API credentials
BUZZDIAL_URL=https://buzzdial.io/api/clicktocall.php
BUZZDIAL_AUTH=
BUZZDIAL_AGENT_NAME=

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Fallback model used ONLY when primary returns 429. Set to "" to disable.
# (v3.4.1)
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
# Cap each Gemini response. 8192 tokens ≈ 32 KB output, under Excel's
# per-cell 32,767-char limit. (v3.3.0)
GEMINI_MAX_OUTPUT_TOKENS=8192
# Min ms between any two outgoing Gemini calls — rate-limit floor.
# 100 = 600 RPM ceiling. Tune to match your Gemini billing tier. (v3.4.0)
GEMINI_MIN_INTERVAL_MS=100
# Reject audio files larger than this (bytes) before Gemini upload starts.
# 100 MB. Files above this fail permanently with no retry burn. (v3.4.0)
GEMINI_MAX_AUDIO_BYTES=104857600

# Analysis worker concurrency. Pair with GEMINI_MIN_INTERVAL_MS — at 10
# concurrent and min-interval=100ms the gate has 7.5x headroom. (v3.4.0)
ANALYSIS_CONCURRENCY=10
# Worker tick interval in seconds.
ANALYSIS_POLL_SEC=5

# JWT
JWT_SECRET=change-me-to-a-long-random-string

# Default admin account (created on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://<server-ip>,https://<your-domain>
